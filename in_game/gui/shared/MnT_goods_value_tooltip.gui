template Mnt_Goods_Value_Tooltip {
	ContextualTooltipType = {
		blockoverride "title_text" {
			text = "Goods Domestic Product"
		}

		blockoverride "tooltip_content" {
			datacontext = "[Player]"

			hbox = {
				layoutpolicy_horizontal = expanding
				spacing = 6
				TooltipTextBlock = {
					blockoverride "text" {
						text = "MNT_URBAN_GDP_LINE"
						default_format = "#help"
					}
					tooltip = "MNT_URBAN_GDP_DESC"
					tooltipwidget = { using = Mnt_Goods_Value_Urban_Breakdown }
				}
				expand = {}
				mapmode_tooltip_button = {
					datacontext = "[GetMapMode('goods_value_urban')]"
				}
			}

			hbox = {
				layoutpolicy_horizontal = expanding
				spacing = 6
				TooltipTextBlock = {
					blockoverride "text" {
						text = "MNT_RURAL_GDP_LINE"
						default_format = "#help"
					}
					tooltip = "MNT_RURAL_GDP_DESC"
					tooltipwidget = { using = Mnt_Goods_Value_Rural_Breakdown }
				}
				expand = {}
				mapmode_tooltip_button = {
					datacontext = "[GetMapMode('goods_value_rural')]"
				}
			}

			hbox = {
				layoutpolicy_horizontal = expanding
				vbox = {
					spacing = 6
					using = bg_text_mask_container_dark_brown
					using = bg_cabinet_card_frame
					margin = { 6 6 }

					hbox = {
						layoutpolicy_horizontal = expanding
						text_single = {
							align = left|nobaseline
							autoresize = yes
							default_format = "#t"
							raw_text = "Goods Output Share"
						}
						expand = {}
					}

					hbox = {
						layoutpolicy_horizontal = expanding
						expand = {}
						piechart = {
							using = bg_circle
							size = { 80 80 }

							using = piechart_angles
							tooltipwidget = {
								ContextualTooltipType = {
									blockoverride "title_icon" {
										icon = {
											using = tooltip_title_icon_size
											texture = "gfx/interface/icons/resources/gold.dds"
										}
									}
									blockoverride "title_text" {
										text = "Goods Output Share"
									}

									blockoverride "tooltip_content" {
										TooltipTextBlock = {
											blockoverride "text" {
												raw_text = "Urban [Select_CFixedPoint(GreaterThan_CFixedPoint(Player.MakeScope.GetVariable('mnt_country_total_goods_value').GetValue, '(CFixedPoint)0'), Divide_CFixedPoint(Player.MakeScope.GetVariable('mnt_country_urban_goods_value').GetValue, Player.MakeScope.GetVariable('mnt_country_total_goods_value').GetValue), '(CFixedPoint)0')|%0] ([Player.MakeScope.GetVariable('mnt_country_urban_goods_value').GetValue|2]@gold!)"
												default_format = "#W"
											}
										}
										TooltipTextBlock = {
											blockoverride "text" {
												raw_text = "Rural [Select_CFixedPoint(GreaterThan_CFixedPoint(Player.MakeScope.GetVariable('mnt_country_total_goods_value').GetValue, '(CFixedPoint)0'), Divide_CFixedPoint(Player.MakeScope.GetVariable('mnt_country_rural_goods_value').GetValue, Player.MakeScope.GetVariable('mnt_country_total_goods_value').GetValue), '(CFixedPoint)0')|%0] ([Player.MakeScope.GetVariable('mnt_country_rural_goods_value').GetValue|2]@gold!)"
												default_format = "#W"
											}
										}
									}
								}
							}

							pieslice_no_highlight = {
								texture = "gfx/interface/pie_charts/pie_chart_alpha_80.dds"
								value = "[FixedPointToFloat(Select_CFixedPoint(GreaterThan_CFixedPoint(Player.MakeScope.GetVariable('mnt_country_total_goods_value').GetValue, '(CFixedPoint)0'), Divide_CFixedPoint(Player.MakeScope.GetVariable('mnt_country_urban_goods_value').GetValue, Player.MakeScope.GetVariable('mnt_country_total_goods_value').GetValue), '(CFixedPoint)0'))]"
								color = { 1.0 0.6 0.1 1.0 }
							}

							pieslice_no_highlight = {
								texture = "gfx/interface/pie_charts/pie_chart_alpha_80_green.dds"
								value = "[Subtract_float('(float)1.0', FixedPointToFloat(Select_CFixedPoint(GreaterThan_CFixedPoint(Player.MakeScope.GetVariable('mnt_country_total_goods_value').GetValue, '(CFixedPoint)0'), Divide_CFixedPoint(Player.MakeScope.GetVariable('mnt_country_urban_goods_value').GetValue, Player.MakeScope.GetVariable('mnt_country_total_goods_value').GetValue), '(CFixedPoint)0')))]"
								color = { 1 1 1 1 }
							}

							icon = {
								size = { 36 36 }
								parentanchor = center
								texture = "gfx/interface/icons/resources/gold.dds"
							}

							using = bg_circle_piechart
						}
						expand = {}
					}
				}
				expand = {}
			}
		}
	}
}

template Mnt_Goods_Value_Urban_Breakdown {
	ContextualTooltipType = {
		blockoverride "title_text" {
			text = "Urban Goods Output Breakdown"
		}

		blockoverride "tooltip_content" {
			datacontext = "[Player]"

			TooltipListScrollArea = {
				blockoverride "block_scrollarea" { maximumsize = { -1 700 } }
				blockoverride "scrollarea_content" {
					vbox = {
						spacing = 4
						set_parent_dimension_to_minimum = height
							TooltipManualTableField = {
								blockoverride "row_size" { maximumsize = { -1 22 } minimumsize = { -1 22 } }
								blockoverride "field_content" {
									block "table_field_margin" { margin = { 6 0 } }
									spacing = 6
									text_single = { align = left|nobaseline autoresize = no minimumsize = { 130 -1 } maximumsize = { 130 -1 } raw_text = "[goods|e]" }
									text_single = { align = center|nobaseline autoresize = no minimumsize = { 50 -1 } maximumsize = { 50 -1 } raw_text = "[location|e]" }
									text_single = { align = center|nobaseline autoresize = no minimumsize = { 90 -1 } maximumsize = { 90 -1 } raw_text = "[gold|e]" }
									expand = {}
									text_single = { align = right|nobaseline autoresize = no minimumsize = { 90 -1 } maximumsize = { 90 -1 } raw_text = "[gold|e] / [location|e]" }
								}
							}
							TooltipManualTableField = {
								blockoverride "visibility" { visible = "[GreaterThan_CFixedPoint(Player.MakeScope.GetVariable('mnt_country_goods_value_cloth').GetValue, '(CFixedPoint)0')]" }
								blockoverride "row_size" {
									maximumsize = { -1 22 }
									minimumsize = { -1 22 }
								}
								blockoverride "field_content" {
									block "table_field_margin" { margin = { 6 0 } }
									spacing = 6
									icon = { size = { 20 20 } texture = "gfx/interface/icons/trade_goods/icon_goods_cloth.dds" texture_density = 2 }
									text_single = { align = left|nobaseline autoresize = no minimumsize = { 130 -1 } maximumsize = { 130 -1 } text = "[ShowGoodsName('cloth')]" }
									text_single = { align = center|nobaseline autoresize = no minimumsize = { 50 -1 } maximumsize = { 50 -1 } raw_text = "[Player.MakeScope.GetVariable('mnt_country_goods_locations_cloth').GetValue|0]" }
									text_single = { align = right|nobaseline autoresize = no minimumsize = { 90 -1 } maximumsize = { 90 -1 } raw_text = "[Player.MakeScope.GetVariable('mnt_country_goods_value_cloth').GetValue|2]@gold!" }
									expand = {}
									text_single = {
										align = right|nobaseline
										autoresize = no
										minimumsize = { 90 -1 }
										maximumsize = { 90 -1 }
										raw_text = "[Divide_CFixedPoint(Player.MakeScope.GetVariable('mnt_country_goods_value_cloth').GetValue, Player.MakeScope.GetVariable('mnt_country_goods_locations_cloth').GetValue)|2]@gold!"
									}
								}
							}
							TooltipManualTableField = {
								blockoverride "visibility" { visible = "[GreaterThan_CFixedPoint(Player.MakeScope.GetVariable('mnt_country_goods_value_fine_cloth').GetValue, '(CFixedPoint)0')]" }
