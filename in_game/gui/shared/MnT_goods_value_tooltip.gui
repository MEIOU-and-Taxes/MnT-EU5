									text_single = { align = left|nobaseline autoresize = no minimumsize = { 130 -1 } maximumsize = { 130 -1 } text = "[ShowGoodsName('fine_cloth')]" }
									text_single = { align = center|nobaseline autoresize = no minimumsize = { 50 -1 } maximumsize = { 50 -1 } raw_text = "[Player.MakeScope.GetVariable('mnt_country_goods_locations_fine_cloth').GetValue|0]" }
