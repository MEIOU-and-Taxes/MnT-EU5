template Estate_tooltip {
	ContextualTooltipType = {
		blockoverride "title_icon_texture" {
			texture = "[GetEstateIcon(Estate.GetType)]"
		}

		blockoverride "title_text" {
			text = "[Estate.GetLongNameWithNoTooltip]"
		}
		blockoverride "title_button" {
			hint_button = {
				action_tooltip = {
					title = "OPEN_HINT"
					on_action = "[OpenLateralViewWithParams('hints', 'selected_hint = hint_estates')]"
				}
			}
		}

		blockoverride "concept_link" {
			text = [estate|E]
		}

		blockoverride "tooltip_content" {
			block "extra_estates_info" {}

			TooltipStringPairList = {
				textcontext = "ESTATE_BREAKDOWN"
			}

			TooltipListBase = {

				TooltipManualTableField = {
					visible = "[Not(Estate.GetType.IsAlwaysLoyal)]"
					text_single = {
						text = "[gold|e]"
					}
					expand = {}
					text_single = {
						raw_text = "[Estate.GetGold|2]([Estate.GetBalance|+=2])@gold!"
					}
				}

				TooltipManualTableField = {
					visible = "[Not(Estate.GetType.IsAlwaysLoyal)]"
					text_single = {
						text = "ESTATE_INCOME"
					}
					expand = {}
					text_single = {
						raw_text = "[Estate.GetLastMonthsIncomeAfterTaxWithTooltip]@gold!"
					}

					tooltipwidget = {
						using = estate_expense_tooltip
					}
				}

				# START: Estate income from lack of control ------------------
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('nobles_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "ESTATE_INCOME_FROM_LACK_OF_CONTROL"
					}
					expand = {}
					text_single = {
						raw_text = "[Estate.GetCountry.MakeScope.GetVariable('mnt_estate_wealth_income_lost_from_control_nobles').GetValue|+=2]@gold!"
					}
				}
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('clergy_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "ESTATE_INCOME_FROM_LACK_OF_CONTROL"
					}
					expand = {}
					text_single = {
						raw_text = "[Estate.GetCountry.MakeScope.GetVariable('mnt_estate_wealth_income_lost_from_control_clergy').GetValue|+=2]@gold!"
					}
				}
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('burghers_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "ESTATE_INCOME_FROM_LACK_OF_CONTROL"
					}
					expand = {}
					text_single = {
						raw_text = "[Estate.GetCountry.MakeScope.GetVariable('mnt_estate_wealth_income_lost_from_control_burghers').GetValue|+=2]@gold!"
					}
				}
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('peasants_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "ESTATE_INCOME_FROM_LACK_OF_CONTROL"
					}
					expand = {}
					text_single = {
						raw_text = "[Estate.GetCountry.MakeScope.GetVariable('mnt_estate_wealth_income_lost_from_control_peasants').GetValue|+=2]@gold!"
					}
				}
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('tribes_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "ESTATE_INCOME_FROM_LACK_OF_CONTROL"
					}
					expand = {}
					text_single = {
						raw_text = "[Estate.GetCountry.MakeScope.GetVariable('mnt_estate_wealth_income_lost_from_control_tribes').GetValue|+=2]@gold!"
					}
				}
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('dhimmi_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "ESTATE_INCOME_FROM_LACK_OF_CONTROL"
					}
					expand = {}
					text_single = {
						raw_text = "[Estate.GetCountry.MakeScope.GetVariable('mnt_estate_wealth_income_lost_from_control_dhimmi').GetValue|+=2]@gold!"
					}
				}
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('cossacks_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "ESTATE_INCOME_FROM_LACK_OF_CONTROL"
					}
					expand = {}
					text_single = {
						raw_text = "[Estate.GetCountry.MakeScope.GetVariable('mnt_estate_wealth_income_lost_from_control_cossacks').GetValue|+=2]@gold!"
					}
				}
				# END: Estate income from lack of control ------------------

				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('nobles_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "ESTATE_DIPLOMATIC_SPENDING_INCOME"
					}
					expand = {}
					text_single = {
						raw_text = "[Estate.GetCountry.MakeScope.GetVariable('noble_diplomatic_spending_transfer').GetValue|+=2]@gold!"
					}
				}

				TooltipManualTableField = {
					visible = "[Not(Estate.GetType.IsAlwaysLoyal)]"
					text_single = {
						text = "ESTATE_FOOD_INCOME"
					}
					expand = {}
					text_single = {
						raw_text = "[Estate.GetFoodIncome|+=2]@gold!"
					}
				}

				TooltipManualTableField = {
					visible = "[Not(Estate.GetType.IsAlwaysLoyal)]"
					text_single = {
						text = "ESTATE_TRADE_INCOME"
					}
					expand = {}
					text_single = {
						raw_text = "[Estate.GetTradeIncome|+=2]@gold!"
					}
				}
				TooltipManualTableField = {
					visible = "[Not(Estate.GetType.IsAlwaysLoyal)]"
					text_single = {
						text = "ESTATE_EXPENSES"
					}
					expand = {}
					text_single = {
						raw_text = "#R -[Estate.GetLastMonthsExpense|2]@gold!#!"
					}
				}
				# START: Estate road maintenance ------------------
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('nobles_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "HEADER_ROAD_MAINTENANCE"
					}
					expand = {}
					text_single = {
						raw_text = "[Multiply_CFixedPoint(Estate.GetCountry.MakeScope.GetVariable('nobles_road_maint').GetValue, '(CFixedPoint)-1')|+=2]@gold!"
					}
				}
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('clergy_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "HEADER_ROAD_MAINTENANCE"
					}
					expand = {}
					text_single = {
						raw_text = "[Multiply_CFixedPoint(Estate.GetCountry.MakeScope.GetVariable('clergy_road_maint').GetValue, '(CFixedPoint)-1')|+=2]@gold!"
					}
				}
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('burghers_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "HEADER_ROAD_MAINTENANCE"
					}
					expand = {}
					text_single = {
						raw_text = "[Multiply_CFixedPoint(Estate.GetCountry.MakeScope.GetVariable('burghers_road_maint').GetValue, '(CFixedPoint)-1')|+=2]@gold!"
					}
				}
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('peasants_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "HEADER_ROAD_MAINTENANCE"
					}
					expand = {}
					text_single = {
						raw_text = "[Multiply_CFixedPoint(Estate.GetCountry.MakeScope.GetVariable('peasants_road_maint').GetValue, '(CFixedPoint)-1')|+=2]@gold!"
					}
				}
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('tribes_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "HEADER_ROAD_MAINTENANCE"
					}
					expand = {}
					text_single = {
						raw_text = "[Multiply_CFixedPoint(Estate.GetCountry.MakeScope.GetVariable('tribes_road_maint').GetValue, '(CFixedPoint)-1')|+=2]@gold!"
					}
				}
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('dhimmi_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "HEADER_ROAD_MAINTENANCE"
					}
					expand = {}
					text_single = {
						raw_text = "[Multiply_CFixedPoint(Estate.GetCountry.MakeScope.GetVariable('dhimmi_road_maint').GetValue, '(CFixedPoint)-1')|+=2]@gold!"
					}
				}
				TooltipManualTableField = {
					visible = "[And(Not(Estate.GetType.IsAlwaysLoyal), ObjectsEqual(Player.GetGovernment.GetEstateFromKey('cossacks_estate').GetType, Estate.GetType))]"
					text_single = {
						text = "HEADER_ROAD_MAINTENANCE"
					}
					expand = {}
					text_single = {
						raw_text = "[Multiply_CFixedPoint(Estate.GetCountry.MakeScope.GetVariable('cossacks_road_maint').GetValue, '(CFixedPoint)-1')|+=2]@gold!"
					}
				}
				# END: Estate road maintenance ------------------
			}


			TooltipTextBlock = {
				visible = "[Estate.IsNextBuildSetUp]"
				blockoverride "text" {
					text = "[Estate.GetCurrentBuildInformation]"
				}
			}

			TooltipTextBlock = {
				visible = "[Not(Estate.GetType.IsAlwaysLoyal)]"
				blockoverride "text" {
					text = "[Estate.GetMostLikedCountries]"
				}

				tooltipwidget = {
					SimpleContextualStringPairTooltipType = {
						blockoverride "title_icon_texture" {
							texture = "[GetEstateIcon(Estate.GetType)]"
						}
						blockoverride "concept_link" {
							text = [estate_opinion|E]
						}

						textcontext = "[Estate.GetMostLikedCountriesFull]"
					}
				}
			}

			TooltipTextBlock = {
				visible = "[Not(Estate.GetType.IsAlwaysLoyal)]"
				blockoverride "text" {
					text = "[Estate.GetLeastLikedCountries]"
				}

				tooltipwidget = {
					SimpleContextualStringPairTooltipType = {
						blockoverride "title_icon_texture" {
							texture = "[GetEstateIcon(Estate.GetType)]"
						}
						blockoverride "concept_link" {
							text = [estate_opinion|E]
						}
						textcontext = "[Estate.GetLeastLikedCountriesFull]"
					}
				}
			}

			TooltipFlavorTextBlock = {
				blockoverride "text" {
					text = "[Estate.GetType.GetFlavorText]"
				}
			}
		}
	}
}